<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">
 
    <display-name>Sistema de Controle de Matrícula</display-name>
 
    <!-- ============================================
         Configuração JSF / Facelets
    ============================================= -->
    <servlet>
        <servlet-name>Faces Servlet</servlet-name>
        <servlet-class>javax.faces.webapp.FacesServlet</servlet-class>
        <load-on-startup>1</load-on-startup>
    </servlet>
 
    <servlet-mapping>
        <servlet-name>Faces Servlet</servlet-name>
        <url-pattern>*.xhtml</url-pattern>
    </servlet-mapping>
 
    <!-- Página de boas-vindas -->
    <welcome-file-list>
        <welcome-file>login.xhtml</welcome-file>
    </welcome-file-list>
 
    <!-- ============================================
         Parâmetros de contexto JSF
    ============================================= -->
 
    <!-- Tema PrimeFaces -->
    <context-param>
        <param-name>primefaces.THEME</param-name>
        <param-value>none</param-value>
        <!-- Usando "none" para aplicar nosso CSS customizado -->
    </context-param>
 
    <!-- Desabilita validação de View State em dev -->
    <context-param>
        <param-name>javax.faces.STATE_SAVING_METHOD</param-name>
        <param-value>server</param-value>
    </context-param>
 
    <!-- Stage do projeto (Development | Production) -->
    <context-param>
        <param-name>javax.faces.PROJECT_STAGE</param-name>
        <param-value>Development</param-value>
    </context-param>
 
    <!-- Encoding -->
    <context-param>
        <param-name>javax.faces.FACELETS_SKIP_COMMENTS</param-name>
        <param-value>true</param-value>
    </context-param>
 
    <!-- ============================================
         Sessão: 30 minutos
    ============================================= -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>
 
    <!-- ============================================
         Página de erro padrão
    ============================================= -->
    <error-page>
        <error-code>404</error-code>
        <location>/erro404.xhtml</location>
    </error-page>
 
</web-app>
